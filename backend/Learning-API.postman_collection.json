              "path": ["api", "profile", "name"]
            }
          }
        },
        {
          "name": "Update Phone",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0987654321\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/profile/phone",
              "host": ["{{base_url}}"],
              "path": ["api", "profile", "phone"]
            }
